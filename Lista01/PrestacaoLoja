import java.util.Scanner;

public class PrestacoesLoja {
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);

        System.out.println("--- Loja Mamão com Açúcar ---");
        System.out.print("Digite o valor total da compra: R$ ");
        double valorCompra = leitor.nextDouble();

        double valorPrestacao = valorCompra / 5;

        System.out.println("\n--- Opções de Pagamento ---");
        System.out.printf("O valor total de R$ %.2f pode ser pago em:%n", valorCompra);
        System.out.printf("5 prestações mensais de: R$ %.2f (sem juros)%n", valorPrestacao);

        leitor.close();
    }
}